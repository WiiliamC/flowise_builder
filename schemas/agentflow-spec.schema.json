{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/flowise-agentflow-builder/v1alpha1",
  "title": "AgentflowSpec v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "flowise-agentflow-builder/v1alpha1" },
    "kind": { "const": "Agentflow" },
    "metadata": { "type": "object", "additionalProperties": false, "required": ["name"], "properties": { "name": { "type": "string", "minLength": 1 }, "description": { "type": "string" }, "labels": { "type": "object", "additionalProperties": { "type": "string" } } } },
    "spec": {
      "type": "object", "additionalProperties": false, "required": ["nodes", "edges"],
      "properties": {
        "flowise": { "type": "object", "additionalProperties": false, "properties": { "targetId": { "type": ["string", "null"] } } },
        "viewport": { "type": "object", "additionalProperties": false, "properties": { "zoom": { "type": "number", "minimum": 0.4, "maximum": 1 } } },
        "nodes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/node" } },
        "edges": { "type": "array", "items": { "$ref": "#/$defs/edge" } }
      }
    }
  },
  "$defs": {
    "key": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
    "node": { "type": "object", "additionalProperties": false, "required": ["key", "component"], "properties": { "key": { "$ref": "#/$defs/key" }, "component": { "type": "string", "minLength": 1 }, "label": { "type": "string" }, "position": { "oneOf": [{ "const": "auto" }, { "type": "object", "additionalProperties": false, "required": ["x", "y"], "properties": { "x": { "type": "number" }, "y": { "type": "number" } } }] }, "size": { "type": "object", "additionalProperties": false, "required": ["width", "height"], "properties": { "width": { "type": "number", "exclusiveMinimum": 0 }, "height": { "type": "number", "exclusiveMinimum": 0 } } }, "inputs": { "type": "object" } } },
    "edge": { "type": "object", "additionalProperties": false, "required": ["from", "to"], "properties": { "from": { "$ref": "#/$defs/key" }, "to": { "$ref": "#/$defs/key" }, "output": { "type": "string" }, "input": { "type": "string" } } }
  }
}
